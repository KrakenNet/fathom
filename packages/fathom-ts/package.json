{
  "name": "@fathom-rules/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Fathom policy engine REST API",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "bash scripts/generate.sh",
    "build": "tsc",
    "docs": "typedoc --plugin typedoc-plugin-markdown --readme none --hideBreadcrumbs --gitRevision master --out ../../docs/reference/typescript-sdk src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.98.1",
    "@types/node": "^25.9.2",
    "typedoc": "~0.28.19",
    "typedoc-plugin-markdown": "~4.12.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.61.1"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=6.4.3",
      "esbuild": ">=0.28.1",
      "js-yaml": ">=4.2.0"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KrakenNet/fathom.git",
    "directory": "packages/fathom-ts"
  }
}